[node name="StoryTell" parent="." unique_id=939186815 instance=ExtResource("24_x6jsp")]
position = Vector2(-1744, 2329)
scale = Vector2(3.48, 3.48)
text = "Verdammt, diese Höhle verzweigt sich immer mehr. Ich muss aufpassen, damit ich wieder aus diesem Labyrinth herausfinde."
set_invisible = true

[node name="StoryTell2" parent="." unique_id=1324586579 instance=ExtResource("24_x6jsp")]
position = Vector2(1528, 2288)
scale = Vector2(3.48, 3.48)
text = "Ich wollte doch nur im Kuipergürtel nach Deuterium suchen. Dass ich jetzt hier unten durch ein feindseliges Höhlensystem schwimme, stand definitiv nicht im Missionsplan."
set_invisible = true

[node name="StoryTell3" parent="." unique_id=1754177921 instance=ExtResource("24_x6jsp")]
position = Vector2(3612, 139)
scale = Vector2(3.48, 3.48)
text = "Ob ich hier auf Haumea auch Deuterium finden kann? Dann hätte sich dieser Ausflug wenigstens gelohnt."
set_invisible = true

[node name="StoryTell4" parent="." unique_id=848635969 instance=ExtResource("24_x6jsp")]
position = Vector2(95.99997, -1554)
scale = Vector2(3.48, 3.48)
text = "Die Kreaturen am Anfang waren noch sehr vereinzelt, fast harmlos. Aber es werden immer mehr...
<next>Als würde ich mich Schicht für Schicht in ein Gebiet vorarbeiten, das nicht für mich gedacht ist."
set_invisible = true

[node name="StoryTell5" parent="." unique_id=1996560592 instance=ExtResource("24_x6jsp")]
position = Vector2(-1711, 603)
scale = Vector2(3.48, 3.48)
text = "Die Pflanzen hier reagieren auf Bewegung. Kaum sichtbar, aber sie tun es.
Ich frage mich, ob sie nur auf Strömungen reagieren – oder auf mich."
set_invisible = true

[node name="StoryTell6" parent="." unique_id=549373326 instance=ExtResource("24_x6jsp")]
position = Vector2(1146, -65)
scale = Vector2(3.48, 3.48)
text = "Die Pflanzen hier reagieren auf Bewegung. Kaum sichtbar, aber sie tun es.
Ich frage mich, ob sie nur auf Strömungen reagieren – oder auf mich."
set_invisible = true

[node name="StoryTell7" parent="." unique_id=1918476041 instance=ExtResource("24_x6jsp")]
position = Vector2(5615, 3639)
scale = Vector2(3.48, 3.48)
text = "Mein Schiff hat schon bessere Tage gesehen. Die Außenhülle hält noch, aber die Angriffe nehmen zu.
<next>Ich sollte eigentlich längst umgedreht sein."
set_invisible = true

[node name="StoryTell8" parent="." unique_id=624342168 instance=ExtResource("24_x6jsp")]
position = Vector2(-745, 3498)
scale = Vector2(3.48, 3.48)
text = "Es gibt keine offiziellen Berichte über Leben auf Haumea. Nicht einmal einfache Mikroorganismen.
Wenn das hier jemand dokumentieren würde, würde es alles verändern."
set_invisible = true

[node name="StoryTell9" parent="." unique_id=1737232125 instance=ExtResource("24_x6jsp")]
position = Vector2(5658, 703)
scale = Vector2(3.48, 3.48)
text = "Ich habe schon oft allein gearbeitet. Wochenlang kein Kontakt, nur ich und mein Schiff.
Aber hier fühlt sich die Einsamkeit… anders an."
set_invisible = true

[node name="StoryTell10" parent="." unique_id=2025650084 instance=ExtResource("24_x6jsp")]
position = Vector2(3794, 2978)
scale = Vector2(3.48, 3.48)
text = "Je mehr Hinweise ich finde, desto weniger ergibt das Gesamtbild Sinn.
Der Pilot war hier, hat gekämpft, ist tiefer gegangen – genau wie ich. Nur warum?"
set_invisible = true

[node name="StoryTell11" parent="." unique_id=1417657150 instance=ExtResource("24_x6jsp")]
position = Vector2(4639, -2331)
scale = Vector2(3.48, 3.48)
text = "Der andere Pilot hat sich offenbar nicht zurückgezogen, obwohl es gefährlicher wurde.
Nicht jeder hätte das getan. Diese Sturheit erinnert mich an mich selbst."
set_invisible = true

[node name="PrematureExitTrigger" parent="." unique_id=888935396 instance=ExtResource("25_rg68n")]
position = Vector2(-4244.0005, 2632)
rotation = 1.5465192
scale = Vector2(2.600005, 2.600005)

