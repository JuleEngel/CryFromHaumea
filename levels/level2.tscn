[node name="StoryTell" parent="." unique_id=2001130204 instance=ExtResource("24_giimr")]
position = Vector2(-1259, -9157.999)
scale = Vector2(3.48, 3.48)
text = "Die Höhle geht immer tiefer. Ich sollte weiter dem Hauptgang folgen und nach Hinweisen auf den Verbleib des Vermissten Ausschau halten. "
set_invisible = true

[node name="StoryTell2" parent="." unique_id=1512845532 instance=ExtResource("24_giimr")]
position = Vector2(2472, -10077)
scale = Vector2(3.48, 3.48)
text = "Da vorne ist wieder so ein Wesen. Sieht ja fast aus wie ein Wal. Hoffentlich ist er dieses Mal freundlicher."
set_invisible = true

[node name="StoryTell3" parent="." unique_id=943319019 instance=ExtResource("24_giimr")]
position = Vector2(9599, -9935)
scale = Vector2(3.48, 3.48)
text = "Die Geräusche aus der Höhle vor mir gefallen mir nicht. Da scheint etwas in der Dunkelheit zu lauern."
set_invisible = true

[node name="StoryTell10" parent="." unique_id=2036079154 instance=ExtResource("24_giimr")]
position = Vector2(7751.0005, -6944.0005)
scale = Vector2(2.6639977, 2.6639977)
text = "Dieses Höhlensystem ist faszinierend. Die ganzen Gänge müssen durch  die Wärme thermaler Aktivität entstanden sein - ein Architekt für einen ganzen Planeten."
set_invisible = true

[node name="StoryTell11" parent="." unique_id=1314813307 instance=ExtResource("24_giimr")]
position = Vector2(7522.244, -4945.578)
scale = Vector2(2.6639977, 2.6639977)
text = "Ich frage mich, wie lange dieses System hier schon existiert. Jahrzehnte? Jahrtausende?"
set_invisible = true

[node name="StoryTell4" parent="." unique_id=1781623198 instance=ExtResource("24_giimr")]
position = Vector2(9005, -8542)
scale = Vector2(3.48, 3.48)
text = "Mit den Tieren dieses Planeten ist nicht zu spaßen. Sie scheinen sich nicht gerade über Besuch zu freuen. Wenigstens sieht der Schwarm an fischähnlichen Tieren da vorne harmlos aus..."
set_invisible = true

[node name="StoryTell5" parent="." unique_id=923808068 instance=ExtResource("24_giimr")]
position = Vector2(11020.824, -5533.3945)
scale = Vector2(3.48, 3.48)
text = "Na super. Der Gang scheint sich zu verzweigen. Und einer ist auch noch durch herabgestürztes Eis blockiert. Da würden nur die Raketen helfen. Wo also lang?"
set_invisible = true

[node name="StoryTell6" parent="." unique_id=534720188 instance=ExtResource("24_giimr")]
position = Vector2(3821, -5856)
scale = Vector2(3.48, 3.48)
text = "Das Wesen da vorne sieht ja aus wie eine Qualle! Na gut, wie eine bösartige Alien-Qualle, die einen nicht wieder loslassen wird. Ich sollte mich von ihren Tentakeln fernhalten..."
set_invisible = true

[node name="StoryTell7" parent="." unique_id=1618287879 instance=ExtResource("24_giimr")]
position = Vector2(-2838, -4479)
scale = Vector2(3.48, 3.48)
text = "Die Geräusche aus dieser Höhle gefallen mir nicht. Da ist mehr als nur ein Wesen... 

<next> Aber ich kann jetzt nicht umdrehen, nicht ohne zu wissen, was passiert ist. Also weiter!"
set_invisible = true

[node name="StoryTell8" parent="." unique_id=1851882991 instance=ExtResource("24_giimr")]
position = Vector2(2955, -3466)
scale = Vector2(3.48, 3.48)
text = "Das waren viele Wesen. Und sie haben mich alle angegriffen. Gegenseitig scheinen sie sich aber nichts zu tun. Warum sind sie mir gegenüber nur so feindselig?"
set_invisible = true

[node name="StoryTell9" parent="." unique_id=167656107 instance=ExtResource("24_giimr")]
position = Vector2(8718, 417)
scale = Vector2(3.48, 3.48)
text = "Das Eis über mir ist mittlerweile vermutlich mehrere Kilometer dick. Verrückt, dass darunter ein ganz eigenes Ökosystem existiert. Was ein wenig Wärme nicht so alles bewirken kann."
set_invisible = true

[node name="StoryTell12" parent="." unique_id=951978858 instance=ExtResource("24_giimr")]
position = Vector2(5202, 2023)
scale = Vector2(3.48, 3.48)
text = "Die Dunkelheit hier ist anders als im offenen All. Dichter. Näher.
Im Weltraum fühlt man sich verloren – hier fühlt man sich... beobachtet?"
set_invisible = true

[node name="StoryTell13" parent="." unique_id=443739368 instance=ExtResource("24_giimr")]
position = Vector2(-3160, 2407)
scale = Vector2(3.48, 3.48)
text = "Ich sollte mich auf die Mission konzentrieren. Jemand braucht Hilfe.
Auch wenn ich langsam das Gefühl bekomme, dass ich hier nicht willkommen bin."
set_invisible = true

[node name="PrematureExitTrigger" parent="." unique_id=888935396 instance=ExtResource("25_vuw6k")]
position = Vector2(-3879, -9081)
rotation = 1.6514786
scale = Vector2(2.600005, 2.600005)

[node name="TriggerOrb" parent="." unique_id=1625650002 instance=ExtResource("24_giimr")]
position = Vector2(5121, -9753)
scale = Vector2(1.2, 1.2)
action = 1
text = "Diese Termalquelle hier versorgt das umliegende Wasser mit Wärme."
image = ExtResource("26_08mxr")

[node name="TriggerOrb2" parent="." unique_id=1994455694 instance=ExtResource("24_giimr")]
position = Vector2(6815, -7565)
scale = Vector2(1.2, 1.2)
action = 1
text = "Dieses Wesen sieht sehr tot aus. Hier wurde auf jeden Fall gekämpft. Scheinbar bin ich auf dem richtigen Weg."
image = ExtResource("27_sxrw6")

[node name="TriggerOrb3" parent="." unique_id=345124821 instance=ExtResource("24_giimr")]
position = Vector2(11218, -4866)
scale = Vector2(1.2, 1.2)
action = 1
text = "Das ist ein Teil von einem U-Boot!"
image = ExtResource("28_sxrw6")

[node name="TriggerOrb4" parent="." unique_id=359343507 instance=ExtResource("24_giimr")]
position = Vector2(1772, -6038)
scale = Vector2(1.2, 1.2)
action = 1
text = "Noch mehr tote Tiere. Anscheinend wurde hier heftig gekämpft."
image = ExtResource("28_vko8m")

[node name="TriggerOrb5" parent="." unique_id=314176533 instance=ExtResource("24_giimr")]
position = Vector2(-530, -2402)
scale = Vector2(1.2, 1.2)
action = 1
text = "Diese Rakete scheint nicht hochgegangen zu sein. Fehlstarter gibt es leider immer wieder."
image = ExtResource("29_jriot")

[node name="TriggerOrb6" parent="." unique_id=188089030 instance=ExtResource("24_giimr")]
position = Vector2(-1843, 1592)
scale = Vector2(1.2, 1.2)
action = 1
text = "Die Pflanze wurde offensichtlich von einem U-Boot getroffen. Ich bin noch auf dem richtigen Weg!"
image = ExtResource("30_hieke")

