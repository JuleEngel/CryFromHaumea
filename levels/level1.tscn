info_text = "Du befindest dich nun in der Eishöhle. Zeit, ein wenig erkunden zu gehen. 

Bewege dein U-Boot mithilfe von WASD, um dich fortzubewegen.

Folge den Gängen, um tiefer in die Höhle zu gelangen."

[node name="InfoScreen2" parent="." unique_id=1507405601 instance=ExtResource("3_2nn5w")]
position = Vector2(-990, -2446)
scale = Vector2(1.52, 1)
info_text = "Ein Eisblock scheint den Weg zu versperren. Zum Glück verfügt dein U-Boot über abschießbare Raketen.

Schieße Raketen ab, indem du die linke Maustaste klickst. Alternativ kannst du sie auch gedrückt halten, um kontinuierlich Raketen abzuschießen.

Um die Raketen zu steuern, lenke sie mit deinem Mauszeiger."

[node name="InfoScreen3" parent="." unique_id=1071936294 instance=ExtResource("3_2nn5w")]
position = Vector2(2701, -1952)
scale = Vector2(1.52, 1)
info_text = "Da unten in der Ecke schimmert etwas matt im Licht der Scheinwerfer. Das solltest du dir mal anschauen!

Erkunde, was sich hinter dem funkelnden Licht versteckt, indem du es mit deinem U-Boot berührst."

[node name="TriggerOrb" parent="." unique_id=93467012 instance=ExtResource("22_ou4v7")]
visible = false
position = Vector2(-372.99997, -1838.9999)
rotation = -0.61289585
scale = Vector2(3.1737154, 2.5269654)
skew = -0.4061799
text = "Unfassbar! In der vorausliegenden Höhle befindet sich eine unbekannte Lebensform. Das ist eine Sensation! Leben verborgen im Inneren eines Eisplaneten!

Schade nur, dass er dir nicht allzu freundlich gesinnt ist. Es bleibt dir wohl nichts anderes übrig, als wieder deine Raketen einzusetzen, wenn du tiefer in die Höhle vordringen möchtest..."
